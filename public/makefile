# ========================
# 基本配置
# ========================
CXX = g++
CXXFLAGS = -std=c++17 -O2 -Wall

# 目录
LIB_DIR = ./lib

# 可执行文件
TARGET = main

# ========================
# 默认目标
# ========================
all: $(TARGET)

# ========================
# 编译 main
# ========================
$(TARGET): main.cpp
	$(CXX) $(CXXFLAGS) $< -L$(LIB_DIR) -lbase -o $@

# ========================
# 清理
# ========================
clean:
	rm -f $(TARGET)

.PHONY: all clean